---
import Base from '../layouts/Base.astro';
import CalendarEmbed from '../components/CalendarEmbed.astro';
import { getCombinedCalendarSources } from '../lib/data';
import { combinedCalendarUrl } from '../lib/calendar';

const sources = await getCombinedCalendarSources();
const calUrl = combinedCalendarUrl({
  sources: sources.map((s) => ({ calendarId: s.calendarId, color: s.color })),
  title: 'WCS MN',
  mode: 'MONTH',
  height: 800,
});
---

<Base title="WCS Minnesota">
  <header class="hero region">
    <div class="wrapper text-center">
      <h1>WCS Minnesota</h1>
    </div>
  </header>

  <article class="region" style="padding-top:1.5rem">
    <div class="wrapper prose flow" style="max-width:60rem;text-align:center">
      <p>
        Welcome! This is an independent, community-driven resource created to
        help dancers discover and stay connected with West Coast Swing events
        and opportunities throughout Minnesota.
      </p>
      <p>
        The project is just getting started, and it grows stronger with
        community involvement. If you have feedback, notice something missing,
        or want to help keep the information up to date, we would love to hear
        from you — please use the <a href="/contact/">Contact page</a> to share
        your thoughts or submit updates.
      </p>
      <p>
        Below you'll find a calendar of public WCS events happening across
        Minnesota. If you know of an event that isn't listed, feel free to send
        it our way so we can include it and help others find it too.
      </p>
      <p>
        You can also explore the
        <a href="/community-resources/">Community Resources page</a> to connect
        with local dancers, organizers, and other helpful resources within the
        scene.
      </p>
      <p>Thanks for being part of the community — and helping it grow!</p>
    </div>

    <div class="wrapper" style="margin-top:2rem">
      <CalendarEmbed src={calUrl} title="WCS Minnesota combined events calendar" height={700} />
    </div>
  </article>
</Base>

<style>
  .hero {
    background: var(--color-primary);
    color: #fff;
    padding-block: clamp(2.5rem, 2rem + 4vw, 5rem);
  }
  .hero h1 {
    color: #fff;
    margin: 0;
  }
</style>
