---
import Base from '../../layouts/Base.astro';
import { getOrganizations } from '../../lib/data';

const orgs = await getOrganizations();
---

<Base
  title="Organizations"
  description="West Coast Swing organizations across Minnesota."
>
  <header class="page-header region">
    <div class="wrapper">
      <span class="eyebrow">The community</span>
      <h1>Organizations</h1>
      <p class="page-header__lead">
        Six groups keep West Coast Swing alive across Minnesota. Each sets its
        own calendar — the homepage just brings them together.
      </p>
    </div>
  </header>

  <article class="region" style="padding-top:0">
    <div class="wrapper">
      <ul class="org-grid">
        {
          orgs.map((org) => (
            <li class="org-card">
              <div
                class="org-card__stripe"
                style={`background:${org.calendarColor ?? '#4467dd'}`}
              />
              <div class="org-card__body">
                <h2>
                  <span
                    class="dot"
                    style={`background:${org.calendarColor ?? '#4467dd'}`}
                  />
                  <a href={`/organizations/${org.slug}/`}>{org.name}</a>
                </h2>
                <p class="org-card__blurb">{org.blurb}</p>
                {org.links.length > 0 && (
                  <div class="chips">
                    {org.links.map((link) => (
                      <a class="chip" href={link.url}>
                        {link.label}
                      </a>
                    ))}
                  </div>
                )}
                <a class="org-card__more" href={`/organizations/${org.slug}/`}>
                  View details →
                </a>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </article>
</Base>

<style>
  .page-header {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
  }
  .page-header__lead {
    color: var(--color-muted);
    max-width: 48rem;
    margin: 0.75rem 0 0;
    font-size: 1.08rem;
  }
</style>
