---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import { getBuildInfo } from '../lib/build';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'A community resource for West Coast Swing in Minnesota.' } = Astro.props;
const fullTitle = title === 'WCS Minnesota' ? title : `${title} — WCS Minnesota`;
const year = new Date().getFullYear();
const build = getBuildInfo();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#dd4462" />
    <link rel="canonical" href={Astro.url.href} />

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible:ital,wght@0,400;0,700;1,400;1,700&family=Red+Hat+Display:wght@500;700;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Nav />
    <main id="main">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="wrapper">
        <div class="site-footer__cols">
          <div>
            <p class="site-footer__lede">WCS Minnesota</p>
            <p class="site-footer__about">
              An independent, community-driven resource for West Coast Swing
              across Minnesota.
            </p>
          </div>
          <nav class="site-footer__nav" aria-label="Explore">
            <h2>Explore</h2>
            <a href="/organizations/">Organizations</a>
            <a href="/#calendar">Calendar</a>
            <a href="/community-resources/">Resources</a>
            <a href="/faq/">FAQ</a>
          </nav>
          <nav class="site-footer__nav" aria-label="Contribute">
            <h2>Contribute</h2>
            <a href="/contributions/add-event/">Add an event</a>
            <a href="/contributions/add-organization/">Add an organization</a>
            <a href="/contributions/contributors/">Contributors</a>
            <a href="/contact/">Contact</a>
          </nav>
          <nav class="site-footer__nav" aria-label="Community">
            <h2>Community</h2>
            <a
              href="https://bulletinboard-one.vercel.app/"
              target="_blank"
              rel="noopener noreferrer">Bulletin Board ↗</a
            >
            <a href="https://github.com/mini-app-polis/website-astro-wcsmn"
              >GitHub ↗</a
            >
          </nav>
        </div>
        <div class="site-footer__bottom">
          <span>© {year} WCS Minnesota</span>
          <span>Version: {build.version} · {build.commit}</span>
        </div>
      </div>
    </footer>

    <style>
      .site-footer {
        margin-top: 4rem;
        background: #1f1f23;
        color: #cfcfd4;
        padding-block: 3.25rem 1.75rem;
        font-size: 0.95rem;
      }
      .site-footer__cols {
        display: grid;
        grid-template-columns: 1.6fr 1fr 1fr 1fr;
        gap: 2rem;
      }
      .site-footer__lede {
        font-family: var(--font-display);
        font-weight: 900;
        color: #fff;
        font-size: 1.1rem;
        margin: 0 0 0.5rem;
      }
      .site-footer__about {
        color: #a4a4ac;
        max-width: 24rem;
        margin: 0;
      }
      .site-footer__nav h2 {
        color: #fff;
        font-size: 1rem;
        margin: 0 0 0.6rem;
      }
      .site-footer__nav a {
        display: block;
        color: #cfcfd4;
        text-decoration: none;
        padding: 0.2rem 0;
      }
      .site-footer__nav a:hover {
        color: #fff;
      }
      .site-footer__bottom {
        margin-top: 2.4rem;
        padding-top: 1.2rem;
        border-top: 1px solid #34343b;
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
        font-size: 0.85rem;
        color: #8b8b93;
      }
      @media (max-width: 780px) {
        .site-footer__cols {
          grid-template-columns: 1fr 1fr;
        }
      }
      @media (max-width: 480px) {
        .site-footer__cols {
          grid-template-columns: 1fr;
        }
      }
    </style>

    <script>
      // Open all external links in a new tab. Covers links in prose and in
      // org bodyHtml (rendered via set:html), not just data-driven markup.
      for (const a of document.querySelectorAll<HTMLAnchorElement>('a[href]')) {
        const href = a.getAttribute('href') ?? '';
        if (!/^https?:\/\//i.test(href)) continue;
        if (new URL(href, location.href).host === location.host) continue;
        a.target = '_blank';
        a.rel = 'noopener noreferrer';
      }
    </script>
  </body>
</html>
