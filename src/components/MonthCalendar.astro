---
// Custom month calendar for the homepage only. Fetches events live from the
// Google Calendar API (public, referrer-restricted key) and renders our own
// color-coded grid — so we fully control the UI (no Google chrome, no
// "+ Google Calendar" button). Org detail pages still use the Google embed.
//
// Data flows through the provider seam: the page builds `sources` from
// getOrganizations(); this component is presentation only.

interface CalendarSource {
  id: string;
  color: string;
  name: string;
}

interface Props {
  sources: CalendarSource[];
  apiKey: string;
  /** Google embed URL, used as the no-JS / error fallback. */
  fallbackSrc?: string;
  timeZone?: string;
}

const {
  sources,
  apiKey,
  fallbackSrc,
  timeZone = 'America/Chicago',
} = Astro.props;
---

<section class="mcal" data-mcal aria-label="WCS Minnesota events calendar">
  <div class="mcal__bar">
    <div class="mcal__nav">
      <button class="mcal__btn" data-mcal-prev aria-label="Previous month">
        <span aria-hidden="true">‹</span>
      </button>
      <h2 class="mcal__title" data-mcal-title aria-live="polite">&nbsp;</h2>
      <button class="mcal__btn" data-mcal-next aria-label="Next month">
        <span aria-hidden="true">›</span>
      </button>
      <button class="mcal__today" data-mcal-today>Today</button>
      <label class="mcal__toggle">
        <input type="checkbox" data-mcal-pasttoggle />
        Show past events
      </label>
    </div>
    <ul class="cal-legend">
      {
        sources.map((s) => (
          <li>
            <span class="dot" style={`background:${s.color}`} />
            {s.name}
          </li>
        ))
      }
    </ul>
  </div>

  <p class="mcal__status" data-mcal-status role="status">Loading events…</p>

  <div class="mcal__grid" data-mcal-grid></div>

  {
    fallbackSrc && (
      <noscript>
        <iframe
          class="calendar-embed"
          src={fallbackSrc}
          title="WCS Minnesota combined events calendar"
          loading="lazy"
          style="height:700px;border:0;width:100%"
        />
      </noscript>
    )
  }

  <div class="mcal__backdrop" data-mcal-backdrop hidden>
    <div
      class="mcal__popover"
      data-mcal-popover
      role="dialog"
      aria-modal="true"
      aria-label="Event details"
    >
      <button class="mcal__popclose" data-mcal-popclose aria-label="Close">
        <span aria-hidden="true">×</span>
      </button>
      <div data-mcal-popbody></div>
    </div>
  </div>
</section>

<script define:vars={{ sources, apiKey, timeZone, fallbackSrc }}>
  (() => {
    const root = document.querySelector('[data-mcal]');
    if (!root) return;

    const grid = root.querySelector('[data-mcal-grid]');
    const titleEl = root.querySelector('[data-mcal-title]');
    const statusEl = root.querySelector('[data-mcal-status]');
    const backdrop = root.querySelector('[data-mcal-backdrop]');
    const popBody = root.querySelector('[data-mcal-popbody]');

    const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
    const DOW = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];

    const fmtTime = new Intl.DateTimeFormat('en-US', { hour: 'numeric', minute: '2-digit', timeZone });
    const fmtFull = new Intl.DateTimeFormat('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric', timeZone });
    // All-day dates are plain calendar dates with no time zone; format them in
    // UTC so they never shift across the viewer's local zone.
    const fmtFullDate = new Intl.DateTimeFormat('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric', timeZone: 'UTC' });
    const dayKeyFmt = new Intl.DateTimeFormat('en-CA', { year: 'numeric', month: '2-digit', day: '2-digit', timeZone });
    // Day header for the schedule (e.g. "Fri"), formatted in UTC from a date key.
    const fmtSchedDow = new Intl.DateTimeFormat('en-US', { weekday: 'short', timeZone: 'UTC' });

    const cache = new Map();
    let view = new Date();
    view = new Date(view.getFullYear(), view.getMonth(), 1);
    let showPast = false;

    const todayKey = dayKeyFmt.format(new Date());

    // First day of the month through the first day of the next month.
    function monthRange(d) {
      const start = new Date(d.getFullYear(), d.getMonth(), 1);
      const end = new Date(d.getFullYear(), d.getMonth() + 1, 1);
      return { start, end };
    }

    function dayKeyOf(dateObj) {
      return dayKeyFmt.format(dateObj);
    }

    // Date keys (YYYY-MM-DD) an event covers.
    function coveredKeys(ev) {
      if (ev.start.date) {
        const keys = [];
        const s = new Date(ev.start.date + 'T00:00:00Z');
        const e = ev.end && ev.end.date ? new Date(ev.end.date + 'T00:00:00Z') : new Date(s.getTime() + 86400000);
        for (let d = new Date(s); d < e; d.setUTCDate(d.getUTCDate() + 1)) {
          keys.push(`${d.getUTCFullYear()}-${String(d.getUTCMonth() + 1).padStart(2, '0')}-${String(d.getUTCDate()).padStart(2, '0')}`);
        }
        return keys.length ? keys : [ev.start.date];
      }
      return [dayKeyOf(new Date(ev.start.dateTime))];
    }

    async function fetchMonth(d) {
      const key = `${d.getFullYear()}-${d.getMonth()}`;
      if (cache.has(key)) return cache.get(key);
      if (!apiKey) throw new Error('NO_KEY');

      const { start, end } = monthRange(d);
      const params = (id) =>
        `key=${encodeURIComponent(apiKey)}&singleEvents=true&orderBy=startTime&maxResults=2500` +
        `&timeMin=${encodeURIComponent(start.toISOString())}` +
        `&timeMax=${encodeURIComponent(end.toISOString())}` +
        `&timeZone=${encodeURIComponent(timeZone)}`;

      const results = await Promise.all(
        sources.map(async (s) => {
          const url = `https://www.googleapis.com/calendar/v3/calendars/${encodeURIComponent(s.id)}/events?${params(s.id)}`;
          const res = await fetch(url);
          if (!res.ok) return [];
          const data = await res.json();
          return (data.items || [])
            .filter((ev) => ev.status !== 'cancelled' && (ev.start?.date || ev.start?.dateTime))
            .map((ev) => ({ ev, color: s.color, org: s.name }));
        })
      );
      const flat = results.flat();
      cache.set(key, flat);
      return flat;
    }

    function startMs(item) {
      const ev = item.ev;
      return new Date(ev.start.dateTime || ev.start.date + 'T00:00:00').getTime();
    }

    // Per-month schedule (agenda) view: a chronological list of the days that
    // have events, each day showing its events in time order.
    function render(events) {
      const ym = `${view.getFullYear()}-${String(view.getMonth() + 1).padStart(2, '0')}`;
      titleEl.textContent = `${MONTHS[view.getMonth()]} ${view.getFullYear()}`;

      const byDay = new Map();
      for (const item of events) {
        for (const k of coveredKeys(item.ev)) {
          if (!k.startsWith(ym)) continue; // keep only days in this month
          if (!byDay.has(k)) byDay.set(k, []);
          byDay.get(k).push(item);
        }
      }
      for (const list of byDay.values()) list.sort((a, b) => startMs(a) - startMs(b));

      // Default: only today and later (YYYY-MM-DD strings compare correctly;
      // todayKey is in the site's time zone). The "Show past events" toggle
      // includes earlier days too.
      const dayKeys = [...byDay.keys()]
        .filter((k) => showPast || k >= todayKey)
        .sort();
      window.__mcalEvents = [];

      if (dayKeys.length === 0) {
        const msg = showPast
          ? 'No events this month.'
          : 'No upcoming events this month.';
        grid.innerHTML = `<p class="mcal__empty">${msg}</p>`;
        return;
      }

      let html = '<ol class="mcal__sched">';
      for (const key of dayKeys) {
        const d = new Date(key + 'T00:00:00Z');
        const dow = fmtSchedDow.format(d);
        const mmdd = `${key.slice(5, 7)}/${key.slice(8, 10)}`;
        const isToday = key === todayKey;

        const rows = byDay
          .get(key)
          .map((item) => {
            const idx = window.__mcalEvents.push(item) - 1;
            const time = item.ev.start.date ? 'All day' : fmtTime.format(new Date(item.ev.start.dateTime));
            const title = (item.ev.summary || 'Event').replace(/</g, '&lt;');
            const org = item.org.replace(/</g, '&lt;');
            return (
              `<button class="mcal__row" data-eid="${idx}">` +
              `<span class="dot" style="background:${item.color}"></span>` +
              `<span class="mcal__rowtime">${time}</span>` +
              `<span class="mcal__rowtitle">${title}</span>` +
              `<span class="mcal__roworg">${org}</span>` +
              `</button>`
            );
          })
          .join('');

        html +=
          `<li class="mcal__day${isToday ? ' is-today' : ''}">` +
          `<div class="mcal__date"><span class="mcal__date-dow">${dow}</span>` +
          `<span class="mcal__date-num">${mmdd}</span></div>` +
          `<div class="mcal__rows">${rows}</div></li>`;
      }
      html += '</ol>';
      grid.innerHTML = html;
    }

    async function load() {
      statusEl.hidden = false;
      statusEl.textContent = 'Loading events…';
      try {
        const events = await fetchMonth(view);
        render(events);
        statusEl.hidden = true;
      } catch (err) {
        grid.innerHTML = '';
        titleEl.textContent = `${MONTHS[view.getMonth()]} ${view.getFullYear()}`;
        statusEl.hidden = false;
        if (err && err.message === 'NO_KEY') {
          statusEl.textContent = 'Calendar isn’t configured yet.';
        } else {
          statusEl.innerHTML = fallbackSrc
            ? `Couldn’t load events right now. <a href="${fallbackSrc}" target="_blank" rel="noopener noreferrer">View on Google Calendar ↗</a>`
            : 'Couldn’t load events right now. Please try again later.';
        }
      }
    }

    function openPopover(item) {
      const ev = item.ev;
      const allDay = !!ev.start.date;
      const startD = new Date(ev.start.dateTime || ev.start.date + 'T00:00:00Z');
      const when = allDay
        ? fmtFullDate.format(startD) + ' · All day'
        : fmtFull.format(startD) + ' · ' + fmtTime.format(startD) +
          (ev.end?.dateTime ? '–' + fmtTime.format(new Date(ev.end.dateTime)) : '');

      popBody.innerHTML = '';
      const dotName = document.createElement('p');
      dotName.className = 'mcal__poporg';
      dotName.innerHTML = `<span class="dot" style="background:${item.color}"></span>`;
      dotName.append(item.org);
      const h = document.createElement('h3');
      h.textContent = ev.summary || 'Event';
      const w = document.createElement('p');
      w.className = 'mcal__popwhen';
      w.textContent = when;
      popBody.append(dotName, h, w);

      if (ev.location) {
        const loc = document.createElement('p');
        loc.className = 'mcal__poploc';
        loc.textContent = ev.location;
        popBody.append(loc);
      }
      if (ev.description) {
        const desc = document.createElement('p');
        desc.className = 'mcal__popdesc';
        desc.textContent = ev.description.replace(/<[^>]*>/g, '').trim();
        popBody.append(desc);
      }
      if (ev.htmlLink) {
        const a = document.createElement('a');
        a.className = 'mcal__poplink';
        a.href = ev.htmlLink;
        a.target = '_blank';
        a.rel = 'noopener noreferrer';
        a.textContent = 'View on Google Calendar ↗';
        popBody.append(a);
      }
      backdrop.hidden = false;
      root.querySelector('[data-mcal-popclose]').focus();
    }

    function closePopover() {
      backdrop.hidden = true;
    }

    grid.addEventListener('click', (e) => {
      const evBtn = e.target.closest('[data-eid]');
      if (!evBtn) return;
      const item = window.__mcalEvents[Number(evBtn.dataset.eid)];
      if (item) openPopover(item);
    });
    backdrop.addEventListener('click', (e) => {
      if (e.target === backdrop) closePopover();
    });
    root.querySelector('[data-mcal-popclose]').addEventListener('click', closePopover);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !backdrop.hidden) closePopover();
    });

    root.querySelector('[data-mcal-prev]').addEventListener('click', () => {
      view = new Date(view.getFullYear(), view.getMonth() - 1, 1);
      load();
    });
    root.querySelector('[data-mcal-next]').addEventListener('click', () => {
      view = new Date(view.getFullYear(), view.getMonth() + 1, 1);
      load();
    });
    root.querySelector('[data-mcal-today]').addEventListener('click', () => {
      const now = new Date();
      view = new Date(now.getFullYear(), now.getMonth(), 1);
      load();
    });
    root.querySelector('[data-mcal-pasttoggle]').addEventListener('change', (e) => {
      showPast = e.target.checked;
      load(); // month data is cached; this just re-renders with the new filter
    });

    load();
  })();
</script>

<style is:global>
  /* Global (not scoped): the grid, cells, and event chips are injected at
     runtime via innerHTML, so they don't carry Astro's scope attribute.
     All selectors are .mcal-prefixed to stay namespaced. */
  .mcal {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-lg);
    overflow: hidden;
    margin-top: 2rem;
  }
  .mcal__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    padding: 1.1rem 1.4rem;
    border-bottom: 1px solid var(--color-border);
  }
  .mcal__nav {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .mcal__title {
    margin: 0;
    font-size: 1.25rem;
    min-width: 11rem;
  }
  .mcal__btn {
    width: 2.1rem;
    height: 2.1rem;
    display: grid;
    place-items: center;
    font-size: 1.3rem;
    line-height: 1;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text);
    border-radius: 0.5rem;
    cursor: pointer;
  }
  .mcal__btn:hover {
    border-color: var(--color-blue);
    color: var(--color-blue);
  }
  .mcal__today {
    margin-left: 0.25rem;
    padding: 0.4rem 0.8rem;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.85rem;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text);
    border-radius: 0.5rem;
    cursor: pointer;
  }
  .mcal__today:hover {
    border-color: var(--color-blue);
    color: var(--color-blue);
  }
  .mcal__toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.45ch;
    margin-left: 0.5rem;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.85rem;
    color: var(--color-muted);
    cursor: pointer;
    user-select: none;
  }
  .mcal__toggle input {
    accent-color: var(--color-pink);
    cursor: pointer;
  }
  .mcal__status {
    margin: 0;
    padding: 1.25rem 1.4rem;
    color: var(--color-muted);
    font-size: 0.95rem;
  }
  .mcal__empty {
    margin: 0;
    padding: 2.5rem 1.4rem;
    text-align: center;
    color: var(--color-muted);
  }
  .mcal__sched {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .mcal__day {
    display: grid;
    grid-template-columns: 4.5rem 1fr;
    gap: 1rem;
    padding: 1rem 1.4rem;
    border-top: 1px solid var(--color-border);
  }
  .mcal__day:first-child {
    border-top: 0;
  }
  .mcal__date {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    padding-top: 0.35rem;
  }
  .mcal__date-dow {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .mcal__date-num {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.15rem;
    line-height: 1.2;
  }
  .mcal__day.is-today .mcal__date-num {
    background: var(--color-pink);
    color: #fff;
    padding: 0.1rem 0.45rem;
    border-radius: 0.5rem;
  }
  .mcal__rows {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .mcal__row {
    display: grid;
    grid-template-columns: auto 5rem 1fr auto;
    align-items: center;
    gap: 0.75rem;
    width: 100%;
    text-align: left;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    cursor: pointer;
    font: inherit;
    color: var(--color-text);
    padding: 0.6rem 0.85rem;
    border-radius: var(--radius-sm);
    transition:
      border-color 0.15s,
      background 0.15s;
  }
  .mcal__row:hover,
  .mcal__row:focus-visible {
    border-color: var(--color-blue);
    background: var(--color-bg);
    outline: none;
  }
  .mcal__rowtime {
    color: var(--color-muted);
    font-size: 0.9rem;
    white-space: nowrap;
  }
  .mcal__rowtitle {
    font-weight: 700;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .mcal__roworg {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.78rem;
    color: var(--color-muted);
    white-space: nowrap;
  }
  @media (max-width: 600px) {
    .mcal__day {
      grid-template-columns: 3.6rem 1fr;
      gap: 0.75rem;
      padding: 0.85rem 1rem;
    }
    .mcal__row {
      grid-template-columns: auto auto 1fr;
      grid-template-rows: auto auto;
      column-gap: 0.6rem;
      row-gap: 0.3rem;
      align-items: start;
    }
    .mcal__row > .dot {
      grid-row: 1;
      grid-column: 1;
      margin-top: 0.4rem;
    }
    .mcal__rowtime {
      grid-row: 1;
      grid-column: 2;
    }
    .mcal__roworg {
      grid-row: 1;
      grid-column: 3;
      justify-self: end;
      text-align: right;
    }
    .mcal__rowtitle {
      grid-row: 2;
      grid-column: 1 / -1;
      white-space: normal;
    }
  }

  .mcal__backdrop {
    position: fixed;
    inset: 0;
    background: rgba(20, 20, 20, 0.45);
    display: grid;
    place-items: center;
    padding: 1rem;
    z-index: 100;
  }
  /* `display: grid` above would otherwise defeat the [hidden] attribute. */
  .mcal__backdrop[hidden] {
    display: none;
  }
  .mcal__popover {
    position: relative;
    background: var(--color-surface);
    color: var(--color-text);
    border-radius: var(--radius);
    box-shadow: var(--shadow-lg);
    max-width: 30rem;
    width: 100%;
    padding: 1.5rem 1.6rem;
  }
  .mcal__popclose {
    position: absolute;
    top: 0.6rem;
    right: 0.7rem;
    width: 2rem;
    height: 2rem;
    border: 0;
    background: transparent;
    font-size: 1.5rem;
    line-height: 1;
    color: var(--color-muted);
    cursor: pointer;
    border-radius: 0.4rem;
  }
  .mcal__popclose:hover {
    background: var(--color-bg);
    color: var(--color-text);
  }
  .mcal__poporg {
    display: flex;
    align-items: center;
    gap: 0.5ch;
    margin: 0 0 0.4rem;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.85rem;
    color: var(--color-muted);
  }
  .mcal__popover h3 {
    margin: 0 0 0.4rem;
    font-size: 1.3rem;
  }
  .mcal__popwhen {
    margin: 0 0 0.5rem;
    font-weight: 700;
  }
  .mcal__poploc,
  .mcal__popdesc {
    margin: 0 0 0.6rem;
    color: var(--color-muted);
    font-size: 0.95rem;
    white-space: pre-line;
  }
  .mcal__poplink {
    font-family: var(--font-display);
    font-weight: 700;
  }
</style>
