---
import { topNav, type NavItem } from '../data/navigation';
import { getOrganizations } from '../lib/data';

const orgs = await getOrganizations();

// External link to the community bulletin board (separate app/subdomain).
const BULLETIN_BOARD_URL = 'https://bulletinboard-one.vercel.app/';

// Inject the Organizations submenu from live org data.
const nav: NavItem[] = topNav.map((item) =>
  item.text === 'Organizations'
    ? {
        ...item,
        submenu: orgs.map((o) => ({
          text: o.name,
          url: `/organizations/${o.slug}/`,
        })),
      }
    : item
);
---

<nav class="site-nav" aria-label="Main">
  <div class="wrapper site-nav__inner">
    <a href="/" class="site-nav__brand" aria-label="WCS Minnesota — home">
      <img
        src="/img/logo.png"
        alt="WCS Minnesota logo"
        class="site-nav__logo"
        height="40"
        loading="eager"
      />
    </a>

    <ul id="primary-menu" class="site-nav__menu">
      {
        nav.map((item) => (
          <li class={item.submenu ? 'has-submenu' : ''}>
            <a href={item.url}>{item.text}</a>
            {item.submenu && (
              <ul class="submenu">
                {item.submenu.map((sub) => (
                  <li>
                    <a href={sub.url}>{sub.text}</a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))
      }
    </ul>

    <div class="site-nav__actions">
      <a
        class="button site-nav__cta"
        href={BULLETIN_BOARD_URL}
        target="_blank"
        rel="noopener noreferrer"
      >
        Bulletin Board <span aria-hidden="true">↗</span>
      </a>
      <button
        class="site-nav__toggle"
        aria-expanded="false"
        aria-controls="primary-menu"
      >
        Menu
      </button>
    </div>
  </div>
</nav>

<style>
  .site-nav {
    background: color-mix(in srgb, var(--color-surface) 86%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 50;
  }
  .site-nav__inner {
    display: flex;
    align-items: center;
    gap: 1rem;
    min-height: 72px;
  }
  .site-nav__brand {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    line-height: 0;
    margin-right: auto;
  }
  .site-nav__logo {
    height: 40px;
    width: auto;
    display: block;
    background: #fff;
    padding: 0.25rem;
    border-radius: 0.25rem;
  }
  .site-nav__menu {
    display: flex;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
    align-items: center;
  }
  .site-nav__menu > li {
    position: relative;
  }
  .site-nav__menu a {
    display: block;
    padding: 0.5rem 0.75rem;
    color: var(--color-text);
    text-decoration: none;
    border-radius: 0.5rem;
    font-family: var(--font-display);
    font-weight: 700;
  }
  .site-nav__menu a:hover,
  .site-nav__menu a:focus-visible {
    background: var(--color-bg);
    color: var(--color-pink-dark);
  }
  .site-nav__actions {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .site-nav__cta {
    padding: 0.55rem 1.1rem;
    font-size: 0.98rem;
  }
  .site-nav__toggle {
    display: none;
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 0.45rem 0.75rem;
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--color-text);
    cursor: pointer;
  }
  .submenu {
    list-style: none;
    margin: 0;
    padding: 0.35rem;
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 12rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow);
    opacity: 0;
    visibility: hidden;
    transform: translateY(4px);
    transition:
      opacity 0.15s,
      transform 0.15s;
  }
  .has-submenu:hover .submenu,
  .has-submenu:focus-within .submenu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  @media (max-width: 880px) {
    .site-nav__toggle {
      display: block;
    }
    .site-nav__menu {
      order: 3;
      flex-basis: 100%;
      display: none;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      padding: 0.25rem 0 0.5rem;
    }
    .site-nav__menu.is-open {
      display: flex;
    }
    .submenu {
      position: static;
      opacity: 1;
      visibility: visible;
      transform: none;
      box-shadow: none;
      border: 0;
      padding-left: 1rem;
    }
  }

  @media (max-width: 480px) {
    .site-nav__cta span {
      display: none;
    }
  }
</style>

<script>
  const toggle = document.querySelector('.site-nav__toggle');
  const menu = document.querySelector('.site-nav__menu');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
  });
</script>
